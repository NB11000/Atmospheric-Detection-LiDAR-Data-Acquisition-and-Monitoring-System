<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AvaloniaApplication_ConfigLauncher.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="550"
        x:Class="AvaloniaApplication_ConfigLauncher.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="数据采集系统 — 配置启动器"
        Width="700" Height="500"
        MinWidth="550" MinHeight="400">

  <Design.DataContext>
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <DockPanel>
    <!-- ── Bottom status bar ──────────────────────────────── -->
    <Border DockPanel.Dock="Bottom"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            Padding="8,4">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto" RowDefinitions="Auto">

        <TextBlock Grid.Column="0" Text="WebAPI 地址:"
                   VerticalAlignment="Center" Margin="0,0,8,0"/>

        <TextBox Grid.Column="1" Text="{Binding BaseUrl}"
                 VerticalAlignment="Center" MinWidth="200"
                 LostFocus="BaseUrlTextBox_LostFocus"/>

        <!-- Connection indicator dot -->
        <Ellipse Grid.Column="2"
                 Width="10" Height="10"
                 Fill="{Binding ConnectionStatusColor}"
                 VerticalAlignment="Center" Margin="12,0,4,0"/>

        <TextBlock Grid.Column="3" Text="{Binding ConnectionStatus}"
                   VerticalAlignment="Center" Margin="0,0,8,0"
                   Foreground="{Binding ConnectionStatusColor}"/>
      </Grid>
    </Border>

    <!-- ── TabControl ─────────────────────────────────────── -->
    <TabControl SelectedIndex="{Binding SelectedTabIndex}">
      <TabItem Header="配置">
        <ContentControl Content="{Binding ConfigVm}"/>
      </TabItem>
      <TabItem Header="控制">
        <ContentControl Content="{Binding ControlVm}"/>
      </TabItem>
      <TabItem Header="日志">
        <ContentControl Content="{Binding LogVm}"/>
      </TabItem>
    </TabControl>
  </DockPanel>

</Window>
