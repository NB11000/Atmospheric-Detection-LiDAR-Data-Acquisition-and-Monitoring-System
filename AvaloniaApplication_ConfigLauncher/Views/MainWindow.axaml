<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AvaloniaApplication_ConfigLauncher.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="550"
        x:Class="AvaloniaApplication_ConfigLauncher.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="数据采集系统 — 配置启动器"
        Width="700" Height="500"
        MinWidth="550" MinHeight="400">

  <Design.DataContext>
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <DockPanel>
    <!-- ── Bottom status bar ──────────────────────────────── -->
    <Border DockPanel.Dock="Bottom"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            Padding="8,4">
      <Grid ColumnDefinitions="Auto,Auto,Auto,Auto" RowDefinitions="Auto">

        <!-- WebAPI 状态 -->
        <Ellipse Grid.Column="0" Width="10" Height="10"
                 Fill="{Binding WebApiConnectionColor}"
                 VerticalAlignment="Center" Margin="0,0,4,0"/>
        <TextBlock Grid.Column="1" Text="{Binding WebApiConnectionStatus, StringFormat='WebAPI: {0}'}"
                   VerticalAlignment="Center" Margin="0,0,16,0"
                   Foreground="{Binding WebApiConnectionColor}"/>

        <!-- MQTT 状态 -->
        <Ellipse Grid.Column="2" Width="10" Height="10"
                 Fill="{Binding MqttConnectionColor}"
                 VerticalAlignment="Center" Margin="0,0,4,0"/>
        <TextBlock Grid.Column="3" Text="{Binding MqttConnectionStatus, StringFormat='MQTT: {0}'}"
                   VerticalAlignment="Center"
                   Foreground="{Binding MqttConnectionColor}"/>
      </Grid>
    </Border>

    <!-- ── TabControl ─────────────────────────────────────── -->
    <TabControl SelectedIndex="{Binding SelectedTabIndex}">
      <TabItem Header="配置">
        <ContentControl Content="{Binding ConfigVm}"/>
      </TabItem>
      <TabItem Header="控制">
        <ContentControl Content="{Binding ControlVm}"/>
      </TabItem>
      <TabItem Header="日志">
        <ContentControl Content="{Binding LogVm}"/>
      </TabItem>
    </TabControl>
  </DockPanel>

</Window>
